# --- App ----------------------------------------------------------------
APP_ENV=development
APP_SECRET_KEY=change-me-to-64-random-chars-please-do-not-leave-this-default
APP_BASE_URL=http://localhost:8000
SESSION_LIFETIME_HOURS=168

# --- Database (overridden by docker-compose for in-cluster networking) --
DATABASE_URL=postgresql+asyncpg://avito:avito@db:5432/avito_monitor

# --- Redis --------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Logging ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
TIMEZONE=Europe/Astrakhan

# --- Avito (фактически используется с Блока 1+) ------------------------
AVITO_PROXY_URL=
AVITO_REQUEST_RATE_LIMIT=1.0

# --- avito-xapi gateway (Блок 1: avito-mcp дёргает его) ----------------
# host.docker.internal на dev-машине = localhost хост-системы (где висит SSH-туннель к homelab).
# В продакшене задаём прямой URL homelab.
AVITO_XAPI_URL=http://host.docker.internal:8080
AVITO_XAPI_API_KEY=test_dev_key_123

# --- avito-mcp ----------------------------------------------------------
# stdio — для локального Claude Code; sse — для backend-воркера.
AVITO_MCP_TRANSPORT=sse
AVITO_MCP_HTTP_PORT=9000
AVITO_MCP_AUTH_TOKEN=dev-mcp-token-change-me

# --- OpenRouter (Блок 3+) ----------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_TEXT_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_DEFAULT_VISION_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_DAILY_USD_LIMIT=10.00

# --- Telegram (Блок 5+) -------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# --- System -------------------------------------------------------------
SYSTEM_PAUSED=false

# --- V2 Messenger Reliability (Stage 3+) -------------------------------
RELIABILITY_ENABLED=true
HEALTH_CHECK_INTERVAL_SEC=300

# --- V2 Messenger Reliability — activity simulator (Stage 5) ----------
ACTIVITY_SIM_ENABLED=true
ACTIVITY_SIM_TIMEZONE=Europe/Astrakhan
ACTIVITY_SIM_WORKHOURS_START=10
ACTIVITY_SIM_WORKHOURS_END=22
ACTIVITY_SIM_ACTIONS_PER_HOUR_WORK=10
ACTIVITY_SIM_ACTIONS_PER_HOUR_OFF=2

# --- V2 Messenger Reliability — messenger-bot (Stage 6) ---------------
MESSENGER_BOT_ENABLED=true
MESSENGER_BOT_TEMPLATE="Здравствуйте! Минуту, сейчас подключится оператор и ответит."
MESSENGER_BOT_RATE_LIMIT_PER_HOUR=60
MESSENGER_BOT_PER_CHANNEL_COOLDOWN_SEC=60
MESSENGER_BOT_WHITELIST_OWN_LISTINGS_ONLY=true
AVITO_OWN_USER_ID=

# --- V2 Messenger Reliability — Telegram alerts (Stage 8) -------------
# Reuses TELEGRAM_BOT_TOKEN above. The first id in TELEGRAM_ALLOWED_USER_IDS
# is the chat target. No-op when either is empty.
RELIABILITY_TG_ALERT_ENABLED=true
RELIABILITY_TG_ALERT_FAIL_THRESHOLD=3
RELIABILITY_TG_ALERT_DAILY_SUMMARY_HOUR=9
