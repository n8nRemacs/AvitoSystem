# /opt/avito-system/.env — production secrets for VPS deployment.
# Copy this file to .env and fill in real values. NEVER commit the live .env.

# --- Domain (Caddy site label) ------------------------------------------
# Empty → Caddy uses "localhost" + self-signed local CA cert (curl -k works,
#   APK won't trust). Set to e.g. avitosystem.duckdns.org once DNS is
#   configured to get a public Let's Encrypt cert.
DOMAIN=

# --- Cloud Supabase (project drwgozasaypgphkxyizt, Frankfurt) -----------
# Postgres pooled URL (transaction mode, port 6543). Used by avito-monitor
# via SQLAlchemy + asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres.drwgozasaypgphkxyizt:Mi31415926pSss!@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?ssl=require

# Supabase REST API endpoint + service-role key. Used by avito-xapi
# (PostgREST client). Get the service-role key from Supabase Dashboard →
# Settings → API → service_role secret.
SUPABASE_URL=https://drwgozasaypgphkxyizt.supabase.co
SUPABASE_KEY=

# --- xapi internal API key ---------------------------------------------
# Plaintext key whose SHA-256 hash is in avito_api_keys.key_hash on Cloud.
# Default value matches the hash already migrated from homelab. Rotate by
# inserting a new (key, sha256(key)) pair into avito_api_keys and updating
# this value + APK Settings.
AVITO_XAPI_API_KEY=test_dev_key_123

# JWT for tenant-auth Bearer tokens (optional; xapi only validates JWTs
# when this is non-empty). Leave blank for X-Api-Key-only mode.
JWT_SECRET=

# --- OpenRouter LLM (avito-monitor) ------------------------------------
OPENROUTER_API_KEY=

# --- Telegram bot (alerts + dashboard interactions) --------------------
# Names match avito-monitor/app/config.py field names.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Optional HTTP/SOCKS proxy if api.telegram.org is blocked from the VPS.
# Leave blank on RU VPS — direct egress works to Telegram CDN.
TELEGRAM_PROXY_URL=

# --- avito-monitor app secrets -----------------------------------------
# Session cookie HMAC. Auto-generate via `openssl rand -hex 32` on first
# deploy. Default kept for compatibility with the existing migrated
# cookie sessions; rotate post-cutover.
APP_SECRET_KEY=

# --- avito-mcp sidecar -------------------------------------------------
# Bearer token clients (Claude Code, APK) send to https://${DOMAIN}/mcp/sse.
# Generate a fresh value on the VPS with `openssl rand -hex 24`.
AVITO_MCP_AUTH_TOKEN=dev-mcp-token-change-me

# --- Avito outbound SOCKS5 proxy ---------------------------------------
# QRATOR на стороне Avito привязывает trust-score JWT к IP, на котором
# токен впервые «обкатан». Avito-app на телефоне ходит через VPN-выход
# 155.212.217.226 (ru-vpn) — все JWT, выпущенные на телефоне, валидны
# только с этого IP. Чтобы наши outbound-запросы из xapi выходили с
# того же IP, поднимаем ssh -D туннель от VPS до ru-vpn, биндим на
# gateway docker-сети 172.18.0.1:1081 (см. systemd unit
# /etc/systemd/system/avito-vpn-tunnel.service на VPS).
# Пустое значение = direct egress (для локальной разработки).
AVITO_SOCKS_PROXY=socks5h://172.18.0.1:1081
