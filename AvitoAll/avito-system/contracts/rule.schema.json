{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rule",
  "description": "AI красный флаг — общее правило для всех поисков",
  "type": "object",
  "required": ["text"],
  "properties": {
    "id": {
      "type": "integer"
    },
    "text": {
      "type": "string",
      "description": "Описание правила (напр. 'Пропускать товары с iCloud Lock')"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "is_preset": {
      "type": "boolean",
      "default": false,
      "description": "Предустановленное правило (не удаляется)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
