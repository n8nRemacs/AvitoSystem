# Token Farm x86 Environment Variables
# Copy this file to .env and edit values

# PostgreSQL
POSTGRES_USER=avito
POSTGRES_PASSWORD=avito_dev_password_x86
POSTGRES_DB=avito_smartfree_x86

# Farm API (if using --profile api)
FARM_API_KEY=dev_key_x86_change_this
FARM_HOST=0.0.0.0
FARM_PORT=8000

# Logging
LOG_LEVEL=DEBUG  # DEBUG for development, INFO for testing

# Environment
ENVIRONMENT=development

# ADB Settings (used by test scripts)
ADB_HOST=localhost
ADB_PORT_1=5555
ADB_PORT_2=5556
ADB_PORT_3=5557

# Testing
RUN_INTEGRATION_TESTS=false
MOCK_AVITO_API=true  # Use mock instead of real Avito API
