# Avito SmartFree Configuration
# Copy to .env and fill in values

# ============== Database ==============
DATABASE_URL=postgresql+asyncpg://avito:avito@localhost:5432/avito_smartfree
POSTGRES_USER=avito
POSTGRES_PASSWORD=avito
POSTGRES_DB=avito_smartfree

# ============== Telegram ==============
# Get from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Comma-separated admin Telegram IDs
TELEGRAM_ADMIN_IDS=123456789,987654321

# ============== Token Farm ==============
# ARM server running Token Farm
FARM_HOST=0.0.0.0
FARM_PORT=8000
FARM_API_KEY=your_secret_api_key
FARM_API_URL=http://farm-server:8000

# ============== Avito ==============
AVITO_WS_URL=wss://socket.avito.ru/socket
AVITO_API_URL=https://api.avito.ru

# ============== Proxy (for registration) ==============
# Mobile proxy for account registration
PROXY_URL=http://user:pass@proxy.example.com:8080

# ============== Logging ==============
LOG_LEVEL=INFO
